{
  "version": "1.0",
  "description": "Contract for feature columns expected by the trading transformer model. Column order is significant — must match the order in MODEL_FEATURE_COLUMNS (ml_main.cpp) and the training pipeline (research/featureEngineering.py).",
  "n_features": 34,
  "features": [
    {"name": "high",          "dtype": "float64", "description": "Daily high price"},
    {"name": "low",           "dtype": "float64", "description": "Daily low price"},
    {"name": "volume",        "dtype": "float64", "description": "Traded volume"},
    {"name": "adj close",     "dtype": "float64", "description": "Adjusted close price"},
    {"name": "P",             "dtype": "float64", "description": "Pivot point"},
    {"name": "R1",            "dtype": "float64", "description": "Resistance level 1"},
    {"name": "R2",            "dtype": "float64", "description": "Resistance level 2"},
    {"name": "R3",            "dtype": "float64", "description": "Resistance level 3"},
    {"name": "S1",            "dtype": "float64", "description": "Support level 1"},
    {"name": "S2",            "dtype": "float64", "description": "Support level 2"},
    {"name": "S3",            "dtype": "float64", "description": "Support level 3"},
    {"name": "obv",           "dtype": "float64", "description": "On-balance volume"},
    {"name": "volume_zscore", "dtype": "float64", "description": "Volume z-score (20-day)"},
    {"name": "rsi",           "dtype": "float64", "description": "14-day RSI"},
    {"name": "macd",          "dtype": "float64", "description": "MACD line"},
    {"name": "macds",         "dtype": "float64", "description": "MACD signal line"},
    {"name": "macdh",         "dtype": "float64", "description": "MACD histogram"},
    {"name": "sma",           "dtype": "float64", "description": "20-day SMA"},
    {"name": "lma",           "dtype": "float64", "description": "50-day SMA"},
    {"name": "sema",          "dtype": "float64", "description": "12-day EMA"},
    {"name": "lema",          "dtype": "float64", "description": "26-day EMA"},
    {"name": "overnight_gap", "dtype": "float64", "description": "Fractional overnight gap (open/prev_close - 1)"},
    {"name": "return_lag_1",  "dtype": "float64", "description": "1-day lagged return"},
    {"name": "return_lag_3",  "dtype": "float64", "description": "3-day lagged return"},
    {"name": "return_lag_5",  "dtype": "float64", "description": "5-day lagged return"},
    {"name": "volatility",    "dtype": "float64", "description": "20-day rolling std of daily returns"},
    {"name": "SR_K",          "dtype": "float64", "description": "Stochastic %K"},
    {"name": "SR_D",          "dtype": "float64", "description": "Stochastic %D"},
    {"name": "SR_RSI_K",      "dtype": "float64", "description": "Stochastic RSI %K"},
    {"name": "SR_RSI_D",      "dtype": "float64", "description": "Stochastic RSI %D"},
    {"name": "ATR",           "dtype": "float64", "description": "14-day average true range"},
    {"name": "HL_PCT",        "dtype": "float64", "description": "High-low percentage (high-low)/close"},
    {"name": "PCT_CHG",       "dtype": "float64", "description": "Daily close percentage change"},
    {"name": "close",         "dtype": "float64", "description": "Close price (target — always last)"}
  ]
}
